{
  "expo": {
    "name": "Dreyk Companion",
    "slug": "dreyk-companion",
    "scheme": "dreykcompanion",
    "experiments": {
      "autolinkingModuleResolution": true
    },
    "android": {
      "package": "com.dreyk.companion",
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION",
        "FOREGROUND_SERVICE",
        "FOREGROUND_SERVICE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_BACKGROUND_LOCATION",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_LOCATION"
      ]
    },
    "ios": {
      "bundleIdentifier": "com.dreyk.companion",
      "infoPlist": {
        "UIBackgroundModes": [
          "location"
        ]
      }
    },
    "plugins": [
      "expo-dev-client",
      "expo-router",
      "expo-asset",
      [
        "expo-location",
        {
          "isAndroidBackgroundLocationEnabled": true,
          "isIosBackgroundLocationEnabled": true,
          "locationAlwaysAndWhenInUsePermission": "Allow Dreyk Companion to use your location for background raw-coordinate tracking.",
          "locationAlwaysPermission": "Allow Dreyk Companion to keep collecting your background location while tracking is active.",
          "locationWhenInUsePermission": "Allow Dreyk Companion to access your location while you use the app."
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "74498474-5f2f-4b2b-a053-34bc2985dee9"
      }
    }
  }
}
