{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "outputs": []
    },
    "typecheck": {
      "outputs": []
    },
    "build": {
      "dependsOn": ["^build"],
      "env": [
        "ALEXA_ACCOUNT_LINKING_CLIENT_ID",
        "ALEXA_ACCOUNT_LINKING_CLIENT_SECRET",
        "ALEXA_ACCOUNT_LINKING_TOKEN_SECRET"
      ],
      "outputs": ["dist/**", ".next/**"]
    }
  }
}
