{
  "name": "dreyk",
  "version": "0.0.0",
  "private": true,
  "packageManager": "npm@11.11.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "lint": "turbo lint",
    "smoke:detection-engine": "psql \"postgresql://postgres:postgres@127.0.0.1:54322/postgres\" -f \"supabase/smoke/detection_engine.sql\"",
    "smoke:ingest-location": "./supabase/smoke/ingest-location.sh",
    "smoke:tracking-points-retention": "psql \"postgresql://postgres:postgres@127.0.0.1:54322/postgres\" -f \"supabase/smoke/tracking_points_retention.sql\"",
    "smoke:voice-integrations": "psql \"postgresql://postgres:postgres@127.0.0.1:54322/postgres\" -f \"supabase/smoke/voice_integrations.sql\"",
    "test:functions": "vitest run --config supabase/functions/vitest.config.ts",
    "typecheck": "turbo typecheck",
    "validate:alexa-release": "node integrations/alexa/validate_release.node.mts",
    "build": "turbo build",
    "format": "prettier --check .",
    "smoke:life-plan-sql": "psql \"postgresql://postgres:postgres@127.0.0.1:54322/postgres\" -f \"supabase/smoke/life_plan_operating.sql\""
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.31.0",
    "@typescript-eslint/parser": "^8.31.0",
    "eslint": "^9.26.0",
    "eslint-config-prettier": "^10.1.2",
    "prettier": "^3.5.3",
    "turbo": "^2.5.0",
    "typescript": "^5.8.3",
    "vitest": "^4.1.6"
  }
}
